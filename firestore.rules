rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    
    function isBackend() {
      return request.auth.token.admin == true;
    }
    
    match /users/{uid} {
      allow read: if isSignedIn() && isOwner(uid);
      
      allow update: if isSignedIn() && isOwner(uid)
        && !('pro' in request.resource.data)
        && !('totalScore' in request.resource.data)
        && !('currentStreak' in request.resource.data)
        && !('bestStreak' in request.resource.data)
        && !('level' in request.resource.data);
      
      allow create: if isSignedIn() && isOwner(uid);

      match /tasks/{taskId} {
        allow read, write: if isSignedIn() && isOwner(uid);
      }
      
      match /daily_logs/{dateId} {
        allow read: if isSignedIn() && isOwner(uid);
        allow create, update, delete: if isBackend();
      }
      
      match /coach_messages/{coachId} {
        allow read: if isSignedIn() && isOwner(uid);
        allow write: if isBackend();
      }
      
      match /badges/{badgeId} {
        allow read: if isSignedIn() && isOwner(uid);
        allow write: if isBackend();
      }
      
      match /challenges/{challengeId} {
        allow read: if isSignedIn() && isOwner(uid);
        allow write: if isBackend();
      }
      
      match /billing/{doc=**} {
        allow read: if isSignedIn() && isOwner(uid);
        allow write: if isBackend();
      }
      
      match /referrals/{refId} {
        allow read: if isSignedIn() && isOwner(uid);
        allow write: if isBackend();
      }
    }
  }
}